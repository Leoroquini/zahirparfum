# ZAHIR PARFUMS — variáveis de ambiente
# Copie este arquivo pra `.env.local` e preencha com os IDs reais quando ativar cada serviço.

# Google Analytics 4 (quando você criar a propriedade no GA)
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Meta Pixel (Facebook/Instagram ads)
# ID numérico obtido no Events Manager
NEXT_PUBLIC_META_PIXEL_ID=

# URL pública do site (usada em metadados SEO/OG)
NEXT_PUBLIC_SITE_URL=https://zahirparfums.com.br
